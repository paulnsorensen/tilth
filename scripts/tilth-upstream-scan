#!/usr/bin/env bash
# Deterministic scanner for the tilth-upstream cloud routine.
#
# Computes how far paulnsorensen/tilth (origin) is ahead of and behind
# jahala/tilth (upstream), then groups fork-only commits into self-contained
# "candidate" upstream contributions: one commit per candidate, filtered to
# files that match agents/tilth-upstream/sources.yaml's upstreamable_globs
# and none of its exclude_globs, sized against max_candidate_files /
# max_candidate_lines, and tested for clean cherry-pick application onto
# upstream/main.
#
# Read-only: never fetches, pushes, or mutates any ref/branch. Callers are
# expected to have already run `git fetch origin <branch>` and
# `git fetch upstream <branch>`. Emits one JSON object on stdout.
set -euo pipefail

cd "$(dirname "$0")/.."

CONFIG="agents/tilth-upstream/sources.yaml"
if [[ ! -f "$CONFIG" ]]; then
  echo "missing config: $CONFIG" >&2
  exit 1
fi

default_branch=$(yq -r '.default_branch' "$CONFIG")
max_files=$(yq -r '.max_candidate_files' "$CONFIG")
max_lines=$(yq -r '.max_candidate_lines' "$CONFIG")

mapfile -t upstreamable_globs < <(yq -r '.upstreamable_globs[]' "$CONFIG")
mapfile -t exclude_globs < <(yq -r '.exclude_globs[]' "$CONFIG")

upstream_ref="upstream/${default_branch}"
origin_ref="origin/${default_branch}"

ahead_by=$(git rev-list --count "${upstream_ref}..${origin_ref}")
behind_by=$(git rev-list --count "${origin_ref}..${upstream_ref}")

if [[ "$behind_by" -gt 0 ]]; then
  sync_needed=true
else
  sync_needed=false
fi

# path_matches_any PATH GLOB [GLOB...] — glob match via bash's extglob-free
# case/esac, same semantics as .gitignore-style single-level '*' plus '**'
# (bash's shopt -s globstar equivalent isn't needed here: '**' collapses to
# '*' under case/esac, which already matches across '/' — sufficient for the
# fixed glob shapes this config uses, e.g. "src/**").
path_matches_any() {
  local path="$1"
  shift
  local pattern
  for pattern in "$@"; do
    case "$path" in
      $pattern) return 0 ;;
    esac
  done
  return 1
}

# path_excluded PATH GLOB [GLOB...] — like path_matches_any, but also checks
# every path-segment suffix, not just the full path from the root. Root-only
# matching lets an excluded dir nested under an allowed prefix evade the
# exclude list (e.g. "src/.claude/x" under upstreamable "src/**" would slip
# past a root-anchored ".claude/**" check). Used only for the exclude-globs
# check — the allow-globs check stays root-anchored via path_matches_any.
path_excluded() {
  local path="$1"
  shift
  local rest="$path"
  while true; do
    if path_matches_any "$rest" "$@"; then
      return 0
    fi
    case "$rest" in
      */*) rest="${rest#*/}" ;;
      *) break ;;
    esac
  done
  return 1
}

# clean_apply SHA — true if cherry-picking SHA onto upstream_ref would apply
# without conflicts. Uses `git merge-tree --write-tree`, a read-only plumbing
# command: it writes content-addressed objects but never touches the working
# tree, index, or any ref.
clean_apply() {
  local sha="$1"
  local parent
  parent=$(git rev-parse "${sha}^" 2>/dev/null) || return 1
  git merge-tree --write-tree --quiet --merge-base="$parent" "$upstream_ref" "$sha" >/dev/null 2>&1
}

candidate_json_list=()

while IFS= read -r sha; do
  [[ -z "$sha" ]] && continue

  mapfile -t files < <(git diff-tree --no-commit-id --name-only -r "$sha")

  reject=false
  keep_files=()
  for f in "${files[@]}"; do
    [[ -z "$f" ]] && continue
    if path_excluded "$f" "${exclude_globs[@]}"; then
      reject=true
      break
    fi
    if path_matches_any "$f" "${upstreamable_globs[@]}"; then
      keep_files+=("$f")
    else
      reject=true
      break
    fi
  done

  if [[ "$reject" == true || ${#keep_files[@]} -eq 0 ]]; then
    continue
  fi

  file_count=${#keep_files[@]}
  line_count=$(git diff-tree --no-commit-id --numstat -r "$sha" | awk '
    $1 ~ /^[0-9]+$/ && $2 ~ /^[0-9]+$/ { total += $1 + $2 }
    END { print total + 0 }
  ')

  subject=$(git log -1 --format=%s "$sha")
  slug=$(printf '%s' "$subject" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' | cut -c1-50)
  key="${slug}-${sha:0:7}"

  if clean_apply "$sha"; then
    applies_clean=true
  else
    applies_clean=false
  fi

  if [[ "$applies_clean" == true && "$file_count" -le "$max_files" && "$line_count" -le "$max_lines" ]]; then
    easy=true
  else
    easy=false
  fi

  files_json=$(printf '%s\n' "${keep_files[@]}" | jq -R . | jq -s .)

  candidate_json=$(jq -n \
    --arg key "$key" \
    --arg sha "$sha" \
    --arg subject "$subject" \
    --argjson files "$files_json" \
    --argjson file_count "$file_count" \
    --argjson line_count "$line_count" \
    --argjson applies_clean "$applies_clean" \
    --argjson easy "$easy" \
    '{
      key: $key,
      commits: [$sha],
      files: $files,
      file_count: $file_count,
      line_count: $line_count,
      applies_clean: $applies_clean,
      subject: $subject,
      easy: $easy
    }')

  candidate_json_list+=("$candidate_json")
done < <(git rev-list --reverse --no-merges "${upstream_ref}..${origin_ref}")

if [[ ${#candidate_json_list[@]} -eq 0 ]]; then
  candidates_json="[]"
else
  candidates_json=$(printf '%s\n' "${candidate_json_list[@]}" | jq -s .)
fi

jq -n \
  --argjson ahead_by "$ahead_by" \
  --argjson behind_by "$behind_by" \
  --argjson sync_needed "$sync_needed" \
  --argjson candidates "$candidates_json" \
  '{
    ahead_by: $ahead_by,
    behind_by: $behind_by,
    sync_needed: $sync_needed,
    candidates: $candidates
  }'
